# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
react-app/node_modules/

# ── Build output ───────────────────────────────────────────────────────────────
dist/
react-app/build/
out/

# ── Native module binaries ─────────────────────────────────────────────────────
*.node
*.dll

# ── Electron cache ─────────────────────────────────────────────────────────────
.cache/
.electron-gyp/

# ── OS files ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ── Logs ───────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
*.log

# ── Env / Secrets ──────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.p12
*.key
*.crt

# ── Code signing certs (NEVER commit these) ────────────────────────────────────
*.pfx
build/certs/

# ── Test coverage ──────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Temp files ─────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
*.orig
