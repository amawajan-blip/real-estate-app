{
  "name": "modir-aqaratek",
  "productName": "Real Estate Manager",
  "version": "1.0.0",
  "description": "Real Estate Manager - Desktop Application",
  "main": "electron/main.js",
  "author": {
    "name": "Real Estate Manager",
    "email": "support@modir-aqaratek.app"
  },
  "license": "MIT",
  "scripts": {
    "react:build": "cd react-app && cross-env CI=false npm run build",
    "electron:dev": "concurrently \"cd react-app && npm start\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:prod": "npm run react:build && electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "build": "npm run react:build && electron-builder --win --x64",
    "dist": "npm run react:build && electron-builder --win --x64",
    "dist:dir": "npm run react:build && electron-builder --win --x64 --dir",
    "start": "npm run electron:dev"
  },
  "keywords": ["electron", "real-estate", "accounting", "desktop"],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.4"
  },
  "build": {
    "appId": "app.modir-aqaratek.desktop",
    "productName": "Real Estate Manager",
    "copyright": "Copyright © 2024 Real Estate Manager",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/bindings/**",
      "**/node_modules/file-uri-to-path/**"
    ],
    "compression": "normal",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "database/**/*",
      "react-app/build/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,readme.md}",
      "!node_modules/*/{test,__tests__,tests,example,examples}",
      "!node_modules/**/*.map",
      "!node_modules/@types/**"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": ["**/*", "!*.txt"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Real Estate Manager",
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "npmRebuild": true
  }
}
